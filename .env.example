# ── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# ── Kinde Auth ───────────────────────────────────────────────────────────────
VITE_KINDE_CLIENT_ID=your_kinde_client_id
VITE_KINDE_DOMAIN=https://your-org.kinde.com

# ── Edge Function Secrets (set in Supabase Dashboard → Project Settings → Edge Functions) ──
# KINDE_DOMAIN=https://your-org.kinde.com          ← must match VITE_KINDE_DOMAIN
# SUPABASE_JWT_SECRET=your_supabase_jwt_secret
# WISE_AI_API_KEY=your_gemini_api_key
# RESEND_API_KEY=your_resend_api_key
# API_KEY_ENCRYPTION_SECRET=your_encryption_secret

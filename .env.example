# ── Auth stack: Appwrite ─────────────────────────────────────────────────────
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_appwrite_project_id

# Local PDF server (npm run dev:pdf-server) reads .env.local and maps VITE_* above.
# You can also set these explicitly:
# APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# APPWRITE_PROJECT_ID=your_appwrite_project_id

# ── Sentry Error Tracking ────────────────────────────────────────────────────
# Get your DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
VITE_SENTRY_DSN=https://your-sentry-dsn@o000000.ingest.sentry.io/0000000

# ── Cloudflare Turnstile (FIX-05) ────────────────────────────────────────────
# Site key is public (set in Vercel env vars). Secret key goes in Appwrite Function env only.
VITE_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key

# ── Appwrite Function Secrets ─────────────────────────────────────────────────
# Set these in Appwrite Console → Functions → [hub] → Settings → Environment Variables
# AND in GitHub → Settings → Secrets and Variables → Actions

# Core
# APPWRITE_API_KEY=your_appwrite_api_key

# Optional: Jina Reader fallback when job boards block direct fetch (Indeed, Glassdoor, etc.)
# JINA_READER_API_KEY=

# Security — Turnstile (ai-gateway hub) — FIX-05
# TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Security — Impersonation HMAC (admin-impersonate + admin-devkit-data hubs) — FIX-02
# IMPERSONATION_HMAC_SECRET=your_impersonation_hmac_secret_32bytes_hex

# Security — Purpose-specific HMAC secrets (Batch 3 — FIX-14)
# ADMIN_TEST_HMAC_SECRET=your_admin_test_hmac_secret    (ai-gateway hub)
# GATEWAY_SMOKE_SECRET=your_gateway_smoke_secret        (ai-gateway hub)
# PUBLIC_SHARE_TOKEN_SECRET=your_public_share_secret    (public-share hub)

# AI Providers (ai-gateway + resume-section-ai hubs)
# WISE_AI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key

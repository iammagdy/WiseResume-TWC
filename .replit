modules = ["nodejs-20", "web", "nix"]
[agent]
expertMode = true
integrations = ["javascript_database:1.0.0"]
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mockup Sandbox"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f 'vite' 2>/dev/null; pkill -f 'tsx.*server' 2>/dev/null; sleep 1; npm run server:dev & npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Mockup Sandbox"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/mockup-sandbox && PORT=8000 BASE_PATH=/__mockup/ npm run dev"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"
isCanvasWorkflow = true

[[ports]]
localPort = 4173
externalPort = 4200

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 5173

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 23636
externalPort = 3000

[[ports]]
localPort = 23637
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
publicDir = "dist"
run = ["npm", "run", "server:prod"]

[userenv]

[userenv.shared]
NODE_ENV = "development"
PUPPETEER_SKIP_DOWNLOAD = "true"
API_PORT = "5001"
VITE_APPWRITE_ENDPOINT = "https://fra.cloud.appwrite.io/v1"
VITE_APPWRITE_PROJECT_ID = "69fd362b001eb325a192"
SKIP_PUPPETEER_CHROME = "1"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

# E2E Test Environment Variables
#
# Copy this file to .env.test and fill in your actual values.
# These are used by the portfolio test fixture scripts.
#
# NEVER commit .env.test with real credentials to git!

# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT=your-project-id-here

# Server-side API Key (required for fixture creation)
# Get this from Appwrite Console → API Keys → Create API Key
# Required scopes: databases.read, databases.write
APPWRITE_API_KEY=your-server-api-key-here

# Test Fixture Credentials (documented for reference)
# These are the default values used by the fixture script:
#
# PUBLIC_PORTFOLIO_USERNAME=testportfolio
# PROTECTED_PORTFOLIO_USERNAME=testprotected
# PROTECTED_PORTFOLIO_PASSWORD=testpass123
# EDGE_CASE_PORTFOLIO_USERNAME=testedgecase

# QA login account for the auth-gated E2E scripts/specs
# (scripts/e2e-*.mjs, scripts/signup-and-send-verification.cjs,
# tests/e2e/specs/27-*). Set these in your local environment only —
# never commit real values.
WISE_RESUME_E2E_EMAIL=
WISE_RESUME_E2E_PASSWORD=

# --- Supabase (same project as the web app) ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ey...

# --- Kinde (same tenant; create a new "Native" application inside it) ---
EXPO_PUBLIC_KINDE_DOMAIN=https://your-tenant.kinde.com
EXPO_PUBLIC_KINDE_CLIENT_ID=your_native_client_id

# --- App identity ---
EXPO_PUBLIC_BUNDLE_ID=com.wiseresume.app
EXPO_PUBLIC_APP_NAME=WiseResume
EXPO_PUBLIC_SCHEME=wiseresume
EXPO_PUBLIC_WEB_URL=https://resume.thewise.cloud

# --- Optional: observability ---
EXPO_PUBLIC_SENTRY_DSN=

# --- Optional: in-app purchases (RevenueCat) ---
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# --- EAS ---
EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_PUBLIC_EAS_UPDATE_URL=

# .boltignore (Removed from here so it can be committed for bolt.new)

# Email preview output (generated by scripts/preview-waitlist-emails.mjs)
email-previews/

# PDF.js + Tesseract.js bundled assets (Task #17). Regenerated from
# node_modules at build time by scripts/copy-pdf-ocr-assets.mjs which is
# wired into `prebuild`. Committing the ~56 MB of WASM and traineddata
# would bloat the repo and we control the build, so the regenerated
# tree is always in sync with the deployed app.
public/pdfjs/
public/tesseract/
scripts/.cache/

# Build/test output files (generated, never commit)
coverage.txt
test_out.txt
lint_output.txt
lint_interview.txt
final_lint.txt
vitest_*.txt
vitest_*.json
*.timestamp-*.mjs
*.pid

# Playwright e2e
tests/e2e/.auth/
tests/e2e/.artifacts/
reports/e2e-html/
reports/e2e-results.json

# Capacitor native platform scaffolds — regenerated on demand via
# `npx cap add ios && npx cap add android`. Treating them as derivative
# artifacts keeps the repo small and avoids platform-specific lockfile
# churn (Pods, Gradle wrappers, etc). See docs/mobile.md.
ios/
android/
.appwrite/

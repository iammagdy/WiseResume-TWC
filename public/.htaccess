Options -MultiViews
RewriteEngine On

# ── Block sourcemap requests (Task #26) ──
# Placed BEFORE the SPA fallback so it fires regardless of whether
# the file exists on disk, and outside <IfModule mod_headers.c> so
# it never depends on mod_headers being loaded. Belt-and-braces:
# the build is configured not to emit *.map files unless
# SENTRY_AUTH_TOKEN is set, but if a future build slips one through
# this rule prevents anyone from downloading the original source.
RewriteRule \.map$ - [F,L,NC]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [QSA,L]

<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co https://*.supabase.in wss://*.supabase.co https://*.kinde.com https://api.openrouter.ai https://api.groq.com https://generativelanguage.googleapis.com https://api.elevenlabs.io; frame-src 'none'; object-src 'none'; base-uri 'self'; script-src 'self'; frame-ancestors 'none'"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # ── Defense-in-depth security headers (Task #26) ──
  # HSTS: force HTTPS for 1 year, cover subdomains, preload-list ready.
  # Safe because the site is already served over HTTPS only.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # Prevent MIME-type sniffing attacks on user-uploaded or static assets.
  Header always set X-Content-Type-Options "nosniff"
  # Isolate the browsing context so cross-origin pages can't share
  # globals with this origin (mitigates XS-Leaks / Spectre-class
  # side-channel attacks). Strict `same-origin` is safe today because
  # Kinde auth uses a top-level redirect flow (no popup, no
  # window.opener dependency) and no current feature opens a popup
  # that needs to postMessage back to this window. If a future
  # feature introduces popup-based OAuth, Stripe Checkout in popup
  # mode, or a popup share dialog, downgrade to
  # `same-origin-allow-popups` (still strong; only loses isolation
  # for popups this origin opens itself).
  Header always set Cross-Origin-Opener-Policy "same-origin"

  # ── Cache-busting for files that MUST be re-fetched on every deploy ──
  # The service worker, app shell, manifests, and changelog control what
  # version users see. If these are cached, returning visitors will keep
  # seeing the old version even after a fresh deploy.
  <FilesMatch "^(custom-sw\.js|sw\.js|service-worker\.js|index\.html|404\.html|manifest.*\.json|changelog\.json|_headers|_redirects|robots\.txt|sitemap\.xml)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # ── Long-cache hashed build assets (safe — filenames change on rebuild) ──
  <FilesMatch "\.(js|css|woff2?|ttf|otf|png|jpg|jpeg|webp|avif|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # The above FilesMatch overrides the previous no-cache for index.html
  # because Apache evaluates rules top-down. Re-assert no-cache for HTML
  # and the explicitly-named control files so they always win.
  <FilesMatch "^(custom-sw\.js|sw\.js|service-worker\.js|index\.html|404\.html|manifest.*\.json|changelog\.json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>

# Ensure correct MIME types (some Hostinger configs miss these)
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType application/json .json
  # PDF.js + Tesseract.js bundled assets (Task #17). Without these,
  # Hostinger serves them as text/html which breaks WASM streaming
  # compilation and Tesseract's traineddata loader.
  AddType application/wasm .wasm
  AddType application/octet-stream .bcmap .traineddata
  AddEncoding gzip .gz
</IfModule>

# Compression for faster initial load
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json image/svg+xml
</IfModule>

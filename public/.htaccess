# Disable Imunify360 / ModSecurity WAF browser challenge
# Hostinger runs mod_security2; SecRuleEngine Off in .htaccess disables
# the challenge page for this site's document root.
<IfModule mod_security.c>
  SecFilterEngine Off
  SecFilterScanPOST Off
</IfModule>
<IfModule mod_security2.c>
  SecRuleEngine Off
</IfModule>

# SPA routing — redirect all non-file, non-dir requests to index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Fix MIME types for ESM workers on Hostinger
<IfModule mod_mime.c>
  AddType application/javascript .mjs
</IfModule>

# Security headers (_headers file is Netlify format and ignored by Apache)
<IfModule mod_headers.c>
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # Cache immutable hashed assets forever; force-revalidate index.html
  <FilesMatch "\.(js|css|woff2?|png|jpg|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

{
  "name": "wise-resume",
  "private": true,
  "version": "4.7.3",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-pdf-ocr-assets.mjs && vite",
    "dev:pdf-server": "npm run build:server && node scripts/dev-pdf-server.mjs",
    "start": "node scripts/copy-pdf-ocr-assets.mjs && vite --host 0.0.0.0 --port 3000",
    "prebuild": "node scripts/copy-pdf-ocr-assets.mjs",
    "build": "tsc --noEmit && vite build && node scripts/check-no-sourcemaps.mjs",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "server": "tsx server/index.ts",
    "server:dev": "tsx --watch server/index.ts",
    "server:prod": "node dist/server.mjs",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist/server.mjs --packages=external",
    "build:all": "npm run build && npm run build:server",
    "db:push": "node_modules/.bin/drizzle-kit push",
    "db:studio": "node_modules/.bin/drizzle-kit studio",
    "db:generate": "node_modules/.bin/drizzle-kit generate",
    "postinstall": "node scripts/copy-pdf-ocr-assets.mjs && node scripts/ensure-puppeteer-chrome.mjs",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:headed": "E2E_HEADED=1 playwright test --project=chromium --headed",
    "test:e2e:report": "playwright show-report reports/e2e-html"
  },
